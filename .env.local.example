# Rendoo Floorplans V1 - Environment Variables Template
# Copy this file to .env.local and fill in your actual credentials

# ============================================
# REQUIRED: AI API Keys
# ============================================

# OpenAI GPT-4o Vision (Primary Strategy)
# Get from: https://platform.openai.com/api-keys
# Cost: ~$0.01-0.05 per floor plan analyzed
OPENAI_API_KEY=sk-proj-your-openai-key-here
# Optional: override OpenAI vision model (default: gpt-4o)
OPENAI_VISION_MODEL=gpt-4o

# Anthropic Claude (Fallback) — REMOVED: project uses only OpenAI GPT-4o Vision
## If you still need Claude for experimentation, re-add the keys locally.

# ============================================
# REQUIRED: Supabase Database
# ============================================

# Project URL (from Supabase Dashboard → Settings → API)
# Format: https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Service Role Key (from Supabase Dashboard → Settings → API)
# KEEP THIS SECRET - Never commit to version control
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key-here

# ============================================
# OPTIONAL: Additional Configuration
# ============================================

# Enable detailed logging (true/false)
DEBUG=false

# Maximum image width for analysis (default: 2000)
MAX_IMAGE_WIDTH=2000

# Cache directory for processed files (default: uploads/cache)
CACHE_DIR=uploads/cache
